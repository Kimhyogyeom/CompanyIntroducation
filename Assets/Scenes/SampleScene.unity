  m_text: "\uBC30\uD130\uB9AC \uD654\uC7AC \uBB38\uC81C\uB97C \uD574\uACB0\uD558\uAE30
    \uC704\uD574 \uC124\uB9BD\uB41C \uD654\uC7AC \uC9C4\uC555 \uC194\uB8E8\uC158,
